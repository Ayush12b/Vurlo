rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin via secure role lookup
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles & Nested Private Collections
    match /users/{userId} {
      // Users can only read or write their own profile document; admins can read all profiles to display customer details
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Prevent modification of role, emailVerified, and admin flags by regular users
      allow write: if request.auth != null 
        && request.auth.uid == userId 
        && (request.resource.data.keys().hasNone(['role', 'emailVerified', 'admin']) 
            || (resource != null 
                && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'emailVerified', 'admin']))));

      // Users can only view or edit items inside their own shopping cart
      match /cart/{productId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.name is string
          && request.resource.data.price is number
          && request.resource.data.price >= 0
          && request.resource.data.image is string
          && request.resource.data.quantity is number
          && request.resource.data.quantity > 0
          && exists(/databases/$(database)/documents/products/$(productId));
      }

      // Users can only view or edit items inside their own wishlist
      match /wishlist/{productId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.name is string
          && request.resource.data.price is number
          && request.resource.data.price >= 0
          && request.resource.data.image is string
          && exists(/databases/$(database)/documents/products/$(productId));
      }

      // Lock down unused orders subcollection
      match /orders/{orderId} {
        allow read, write: if false;
      }
    }

    // Orders Collection
    match /orders/{orderId} {
      // Authenticated users can place/create orders under their own userId with strict validation
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.shippingDetails is map
        && request.resource.data.shippingDetails.keys().hasAll(['name','address','city','pinCode','phone']);
        
      // Users can view their own order records; admins can view all orders
      allow read: if request.auth != null 
        && (resource.data.userId == request.auth.uid || isAdmin());
        
      // Admins can update order status (e.g. pending, shipped, delivered)
      allow update: if isAdmin();
      
      // Block all deletions to order records
      allow delete: if false;
    }

    // Public Product Catalog
    match /products/{productId} {
      // Anyone can fetch or list the product catalog publicly
      allow read: if true;
      
      // Admin users are allowed to add, edit, or delete products;
      // Authenticated users can update/decrement stock during order placement
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
        request.resource.data.stock is number &&
        request.resource.data.stock >= 0
      );
      allow create, delete: if isAdmin();
    }
  }
}
